# ═══════════════════════════════════════════════════════════════════
# Gibson — Environment Variables
# Copy to .env and fill in values
# Every variable here MUST be documented before use in code
# ═══════════════════════════════════════════════════════════════════

# ─── Database (Supabase PostgreSQL) ───────────────────────────────
# Find these in: Supabase → Project Settings → Database / API
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_POOL_SIZE=10
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (Vision + Synthesis) ──────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
ANTHROPIC_SYNTHESIS_MODEL=claude-haiku-4-5-20251001

# ─── Local LLM (after migration — not Month 1) ──────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# ─── Pricing APIs ────────────────────────────────────────────────
BOOKSRUN_API_KEY=
BOOKSRUN_AFFILIATE_ID=
BOOKSCOUTER_API_KEY=
VIALIBRI_BASE_URL=https://www.vialibri.net
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

# ─── Sales Channels ─────────────────────────────────────────────
BIBLIO_API_KEY=
WHATNOT_API_KEY=

# ─── Image Storage (Cloudflare R2) ──────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gibson-images
R2_PUBLIC_URL=
# Local replacement (post-migration):
LOCAL_IMAGE_PATH=/data/images

# ─── Notifications ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Store Config ────────────────────────────────────────────────
STORE_DL_ID=
STORE_MG_ID=

# ─── Feature Flags ──────────────────────────────────────────────
USE_LOCAL_LLM=false
USE_LOCAL_CLIP=false
SHELFIE_ENABLED=false
AGENT_ENABLED=false
WHATNOT_LIVE_CAMERA=false

# ─── Training Pipeline ──────────────────────────────────────────
# KEEP FALSE on the cloud server. Only enable on a local machine
# that has Ollama + Llama 3 8B set up for QLoRA fine-tuning.
# When false: corrections are still recorded but never marked as
# training pairs, and training_export.py refuses to run.
TRAINING_ENABLED=false

# ─── Server ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
JWT_SECRET=
