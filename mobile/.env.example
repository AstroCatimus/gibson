# Gibson Mobile — Environment
# Copy to .env and fill in values
# EXPO_PUBLIC_ prefix makes vars available in the app bundle

# Backend API — use your Railway URL in production, or your Mac's local IP for device testing
# Local:      http://192.168.x.x:8000
# Production: https://your-app.railway.app
EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:8000

# Supabase — find these in: Supabase → Project Settings → API
# The anon key is safe to expose (it's rate-limited and RLS-protected)
EXPO_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Store IDs — find these in Supabase → Table Editor → gibson_store
EXPO_PUBLIC_DEFAULT_STORE_ID=
EXPO_PUBLIC_DL_STORE_ID=
EXPO_PUBLIC_MG_STORE_ID=
